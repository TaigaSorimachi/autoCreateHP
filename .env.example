# ========================================
# アポ太郎 — 環境変数設定
# ========================================
# このファイルを .env にコピーして値を設定
# cp .env.example .env
# ========================================

# Google Places API Key（必須：実データ使用時）
# 取得方法: https://console.cloud.google.com/
# 有効化するAPI: Places API, Geocoding API
GOOGLE_PLACES_API_KEY=

# Unsplash API Access Key（推奨：画像フォールバック用）
# 取得方法: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# サーバー設定（変更任意）
HOST=127.0.0.1
PORT=5000
